procedure TFormConfigBoletim.CarregarDisciplinasFirebase;
var
  HTTP: TNetHTTPClient;
  Response: IHTTPResponse;
  URL: string;
  JSONObj: TJSONObject;
  Documents: TJSONArray;
  Doc: TJSONValue;
  i: Integer;
  Fields: TJSONObject;
  Codigo: Integer;
  Nome: string;
  OrdemArray: TJSONArray;
  OrdemField: TJSONValue;
  TemOrdem: Boolean;
  j: Integer;
  CodigoNaOrdem: Integer;
  DisciplinaEncontrada: Boolean;
begin
  MostrarStatus('Carregando disciplinas...', clBlue);
  lbDisciplinas.Clear;
  SetLength(FDisciplinas, 0);
  SetLength(FOrdemDisciplinas, 0);

  HTTP := TNetHTTPClient.Create(nil);
  try
    // Primeiro, buscar a ordem salva na configuração
    URL := Format('https://firestore.googleapis.com/v1/projects/%s/databases/(default)/documents/config_boletim/%s?key=%s',
      [FIREBASE_PROJECT, CONFIG_DOCUMENT_ID, FIREBASE_API_KEY]);

    TemOrdem := False;
    try
      Response := HTTP.Get(URL);
      if Response.StatusCode = 200 then
      begin
        JSONObj := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
        try
          Fields := JSONObj.GetValue('fields') as TJSONObject;
          if Assigned(Fields) then
          begin
            OrdemField := Fields.GetValue('ordem_disciplinas');
            if Assigned(OrdemField) then
            begin
              OrdemArray := (OrdemField as TJSONObject).GetValue('arrayValue') as TJSONArray;
              if Assigned(OrdemArray) then
              begin
                SetLength(FOrdemDisciplinas, OrdemArray.Count);
                for j := 0 to OrdemArray.Count - 1 do
                begin
                  OrdemField := (OrdemArray.Items[j] as TJSONObject).GetValue('integerValue');
                  if Assigned(OrdemField) then
                    FOrdemDisciplinas[j] := StrToIntDef(OrdemField.Value, 0);
                end;
                TemOrdem := Length(FOrdemDisciplinas) > 0;
              end;
            end;
          end;
        finally
          JSONObj.Free;
        end;
      end;
    except
      // Ignorar erro ao buscar ordem
    end;

    // Buscar disciplinas da coleção
    URL := Format('https://firestore.googleapis.com/v1/projects/%s/databases/(default)/documents/disciplinas?key=%s',
      [FIREBASE_PROJECT, FIREBASE_API_KEY]);

    Response := HTTP.Get(URL);

    if Response.StatusCode = 200 then
    begin
      JSONObj := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
      try
        Documents := JSONObj.GetValue('documents') as TJSONArray;
        if Assigned(Documents) then
        begin
          SetLength(FDisciplinas, Documents.Count);
          for i := 0 to Documents.Count - 1 do
          begin
            Doc := Documents.Items[i];
            Fields := (Doc as TJSONObject).GetValue('fields') as TJSONObject;

            if Assigned(Fields) then
            begin
              // Ler código
              Codigo := 0;
              OrdemField := Fields.GetValue('codigo');
              if Assigned(OrdemField) then
                Codigo := StrToIntDef((OrdemField as TJSONObject).GetValue('integerValue').Value, 0);

              // Ler nome
              Nome := '';
              OrdemField := Fields.GetValue('nome');
              if Assigned(OrdemField) then
                Nome := (OrdemField as TJSONObject).GetValue('stringValue').Value;

              FDisciplinas[i].Codigo := Codigo;
              FDisciplinas[i].Nome := Nome;
            end;
          end;

          if TemOrdem then
            AplicarOrdemDisciplinas
          else
            RestaurarOrdemPadrao;

          MostrarStatus(Format('%d disciplinas carregadas!', [Length(FDisciplinas)]), clGreen);
        end
        else
        begin
          MostrarStatus('Nenhuma disciplina encontrada.', clRed);
        end;
      finally
        JSONObj.Free;
      end;
    end
    else
    begin
      MostrarStatus('Erro ao carregar disciplinas: ' + IntToStr(Response.StatusCode), clRed);
    end;
  except
    on E: Exception do
      MostrarStatus('Erro: ' + E.Message, clRed);
  end;
  HTTP.Free;
end;

procedure TFormConfigBoletim.AplicarOrdemDisciplinas;
var
  DisciplinasOrdenadas: array of TDisciplinaItem;
  i, j: Integer;
  CodigoOrdem: Integer;
  DisciplinaEncontrada: Boolean;
begin
  // Criar array ordenado baseado em FOrdemDisciplinas
  SetLength(DisciplinasOrdenadas, Length(FOrdemDisciplinas));

  for i := 0 to High(FOrdemDisciplinas) do
  begin
    CodigoOrdem := FOrdemDisciplinas[i];
    DisciplinasOrdenadas[i].Codigo := CodigoOrdem;
    DisciplinasOrdenadas[i].Nome := 'Disciplina ' + IntToStr(CodigoOrdem);

    // Buscar nome da disciplina
    for j := 0 to High(FDisciplinas) do
    begin
      if FDisciplinas[j].Codigo = CodigoOrdem then
      begin
        DisciplinasOrdenadas[i].Nome := FDisciplinas[j].Nome;
        Break;
      end;
    end;
  end;

  // Adicionar disciplinas que não estão na ordem
  for i := 0 to High(FDisciplinas) do
  begin
    DisciplinaEncontrada := False;
    for j := 0 to High(FOrdemDisciplinas) do
    begin
      if FOrdemDisciplinas[j] = FDisciplinas[i].Codigo then
      begin
        DisciplinaEncontrada := True;
        Break;
      end;
    end;

    if not DisciplinaEncontrada then
    begin
      SetLength(DisciplinasOrdenadas, Length(DisciplinasOrdenadas) + 1);
      DisciplinasOrdenadas[High(DisciplinasOrdenadas)] := FDisciplinas[i];
    end;
  end;

  // Atualizar array principal e ListBox
  SetLength(FDisciplinas, Length(DisciplinasOrdenadas));
  for i := 0 to High(DisciplinasOrdenadas) do
    FDisciplinas[i] := DisciplinasOrdenadas[i];

  lbDisciplinas.Clear;
  for i := 0 to High(FDisciplinas) do
    lbDisciplinas.Items.Add(Format('%d - %s', [FDisciplinas[i].Codigo, FDisciplinas[i].Nome]));
end;

procedure TFormConfigBoletim.RestaurarOrdemPadrao;
var
  i: Integer;
  Temp: TDisciplinaItem;
  j: Integer;
begin
  // Ordenar por código (ordem padrão)
  for i := 0 to High(FDisciplinas) - 1 do
  begin
    for j := i + 1 to High(FDisciplinas) do
    begin
      if FDisciplinas[i].Codigo > FDisciplinas[j].Codigo then
      begin
        Temp := FDisciplinas[i];
        FDisciplinas[i] := FDisciplinas[j];
        FDisciplinas[j] := Temp;
      end;
    end;
  end;

  // Atualizar ListBox
  lbDisciplinas.Clear;
  for i := 0 to High(FDisciplinas) do
    lbDisciplinas.Items.Add(Format('%d - %s', [FDisciplinas[i].Codigo, FDisciplinas[i].Nome]));

  // Atualizar array de ordem
  SetLength(FOrdemDisciplinas, Length(FDisciplinas));
  for i := 0 to High(FDisciplinas) do
    FOrdemDisciplinas[i] := FDisciplinas[i].Codigo;
end;

procedure TFormConfigBoletim.MoverItemParaCima;
var
  Indice: Integer;
  Temp: TDisciplinaItem;
  TempCod: Integer;
begin
  Indice := lbDisciplinas.ItemIndex;
  if (Indice > 0) and (Indice < Length(FDisciplinas)) then
  begin
    // Trocar no array de disciplinas
    Temp := FDisciplinas[Indice];
    FDisciplinas[Indice] := FDisciplinas[Indice - 1];
    FDisciplinas[Indice - 1] := Temp;

    // Trocar no array de ordem
    TempCod := FOrdemDisciplinas[Indice];
    FOrdemDisciplinas[Indice] := FOrdemDisciplinas[Indice - 1];
    FOrdemDisciplinas[Indice - 1] := TempCod;

    // Atualizar ListBox
    lbDisciplinas.Items[Indice] := Format('%d - %s', [FDisciplinas[Indice].Codigo, FDisciplinas[Indice].Nome]);
    lbDisciplinas.Items[Indice - 1] := Format('%d - %s', [FDisciplinas[Indice - 1].Codigo, FDisciplinas[Indice - 1].Nome]);

    lbDisciplinas.ItemIndex := Indice - 1;
  end;
end;

procedure TFormConfigBoletim.MoverItemParaBaixo;
var
  Indice: Integer;
  Temp: TDisciplinaItem;
  TempCod: Integer;
begin
  Indice := lbDisciplinas.ItemIndex;
  if (Indice >= 0) and (Indice < Length(FDisciplinas) - 1) then
  begin
    // Trocar no array de disciplinas
    Temp := FDisciplinas[Indice];
    FDisciplinas[Indice] := FDisciplinas[Indice + 1];
    FDisciplinas[Indice + 1] := Temp;

    // Trocar no array de ordem
    TempCod := FOrdemDisciplinas[Indice];
    FOrdemDisciplinas[Indice] := FOrdemDisciplinas[Indice + 1];
    FOrdemDisciplinas[Indice + 1] := TempCod;

    // Atualizar ListBox
    lbDisciplinas.Items[Indice] := Format('%d - %s', [FDisciplinas[Indice].Codigo, FDisciplinas[Indice].Nome]);
    lbDisciplinas.Items[Indice + 1] := Format('%d - %s', [FDisciplinas[Indice + 1].Codigo, FDisciplinas[Indice + 1].Nome]);

    lbDisciplinas.ItemIndex := Indice + 1;
  end;
end;

procedure TFormConfigBoletim.SalvarOrdemDisciplinas;
var
  i: Integer;
begin
  // Atualizar array de ordem baseado na ordem atual do array FDisciplinas
  SetLength(FOrdemDisciplinas, Length(FDisciplinas));
  for i := 0 to High(FDisciplinas) do
    FOrdemDisciplinas[i] := FDisciplinas[i].Codigo;
end;

end.
