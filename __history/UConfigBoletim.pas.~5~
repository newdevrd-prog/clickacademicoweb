function TFormConfigBoletim.HexParaColor(const Hex: string): TColor;
var
  HexValue: string;
  R, G, B: Byte;
begin
  HexValue := Hex;
  if HexValue.StartsWith('#') then
    HexValue := HexValue.Substring(1);

  if HexValue.Length = 6 then
  begin
    R := StrToInt('$' + HexValue.Substring(0, 2));
    G := StrToInt('$' + HexValue.Substring(2, 2));
    B := StrToInt('$' + HexValue.Substring(4, 2));
    Result := RGB(R, G, B);
  end
  else
    Result := clGreen; // Padrao se invalido
end;

function TFormConfigBoletim.ColorParaHex(const Color: TColor): string;
var
  R, G, B: Byte;
begin
  R := GetRValue(Color);
  G := GetGValue(Color);
  B := GetBValue(Color);
  Result := Format('#%.2x%.2x%.2x', [R, G, B]);
end;

