procedure TFormExportarBoletim.FormCreate(Sender: TObject);
begin
  FSyncService := TSyncServiceAPI.Create;
  FSyncService.OnProgress := OnSyncProgress;
  ConfigurarConexao;
  CarregarGridEnvios;
  Log('Sistema iniciado. Aguardando comando...');
end;

procedure TFormExportarBoletim.FormDestroy(Sender: TObject);
begin
  FSyncService.Free;
end;

procedure TFormExportarBoletim.ConfigurarConexao;
begin
  FDConnection.Params.DriverID := 'FB';
  FDConnection.Params.Database := 'C:\ClickAcademico\ClickAcademico.fdb';
  FDConnection.Params.UserName := 'SYSDBA';
  FDConnection.Params.Password := 'masterkey';
  FDConnection.Params.Add('Protocol=TCPIP');
  FDConnection.Params.Add('Server=localhost');
  FDConnection.Params.Add('Port=3050');
  FDConnection.LoginPrompt := False;
  
  try
    FDConnection.Connected := True;
    Log('Conectado ao Firebird com sucesso!');
  except
    on E: Exception do
    begin
      Log('Erro ao conectar ao Firebird: ' + E.Message, False);
      raise;
    end;
  end;
end;

procedure TFormExportarBoletim.Log(const Msg: string; Success: Boolean);
begin
  if Success then
    MemoLog.Lines.Add(Format('[%s] %s', [FormatDateTime('hh:nn:ss', Now), Msg]))
  else
    MemoLog.Lines.Add(Format('[%s] ERRO: %s', [FormatDateTime('hh:nn:ss', Now), Msg]));
  Application.ProcessMessages;
end;

procedure TFormExportarBoletim.OnSyncProgress(const Msg: string; Success: Boolean);
begin
  Log(Msg, Success);
end;

procedure TFormExportarBoletim.CarregarGridEnvios;
begin
  FDQueryEnvios.Close;
  FDQueryEnvios.SQL.Text := 
    'SELECT ID, DATA_ENVIO, ANO_LETIVO, ID_ENVIO_FIREBASE, QUANTIDADE_REGISTROS, TURMA_CODIGO, STATUS ' +
    'FROM ENVIO_BOLETINS ORDER BY DATA_ENVIO DESC';
  try
    FDQueryEnvios.Open;
    Log('Grid de envios atualizado.');
  except
    on E: Exception do
      Log('Tabela ENVIO_BOLETINS nao existe ainda. Sera criada no primeiro envio. ' + E.Message, False);
  end;
end;

