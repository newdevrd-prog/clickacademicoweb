          if Response.StatusCode in [200, 201] then
          begin
            Inc(Quantidade);

            // Atualizar progress bar a cada registro
            ProgressBar.Position := Quantidade;
            lblProgresso.Caption := Format('Exportando: %d de %d registros', [Quantidade, TotalRegistros]);

            // Log a cada 10 registros
            if (Quantidade mod 10) = 0 then
            begin
              Log(Format('Exportados: %d de %d registros (%.0f%%)...',
                [Quantidade, TotalRegistros, (Quantidade / TotalRegistros) * 100]));
            end;

            Application.ProcessMessages;
          end
          else
          begin
            Log('Erro no registro ' + FDQueryBoletim.RecNo.ToString + ': ' + Response.StatusText, False);
          end;
        finally
          RequestStream.Free;
        end;
      finally
        JSONDoc.Free;
      end;

      FDQueryBoletim.Next;
    end;

    Log(Format('Exportacao concluida. Total: %d de %d registros (%.0f%%).',
      [Quantidade, TotalRegistros, (Quantidade / TotalRegistros) * 100]));
  finally
    HTTP.Free;
  end;
end;

procedure TFormExportarBoletim.btnExportarClick(Sender: TObject);
var
  IdEnvioFirebase: string;
  Quantidade: Integer;
  TotalRegistros: Integer;
begin
  Log('========================================');
  Log('INICIANDO EXPORTACAO DO BOLETIM');
  Log('========================================');

  btnExportar.Enabled := False;
  ProgressBar.Visible := True;
  lblProgresso.Visible := True;
  try
    // 1. Criar tabela local se nao existir
    CriarTabelaEnvioBoletins;

    // 2. Executar query para carregar dados do ano selecionado
    ExecutarQueryBoletim(ObterAnoLetivoSelecionado);

    if FDQueryBoletim.IsEmpty then
    begin
      Log('Nenhum dado encontrado para exportar.', False);
      Exit;
    end;

    // Garantir que temos o total correto de registros
    FDQueryBoletim.Last;
    FDQueryBoletim.First;
    TotalRegistros := FDQueryBoletim.RecordCount;
    Log('Total de registros para exportar: ' + TotalRegistros.ToString);

    // Configurar progress bar (Max deve ser configurado apos Min e com valor correto)
    ProgressBar.Min := 0;
    ProgressBar.Max := TotalRegistros;
    ProgressBar.Position := 0;
    ProgressBar.Step := 1;
    lblProgresso.Caption := Format('Exportando: 0 de %d registros', [TotalRegistros]);
    Application.ProcessMessages;

    // 3. Criar documento de envio no Firebase
    IdEnvioFirebase := CriarEnvioFirebase;
    if IdEnvioFirebase = '' then
    begin
      Log('Falha ao criar envio no Firebase. Abortando.', False);
      Exit;
    end;

    // 4. Exportar dados para boletim_alunos com referencia ao envio (com progresso)
    ExportarDadosComProgresso(IdEnvioFirebase, Quantidade, TotalRegistros, ObterAnoLetivoSelecionado);

    // 5. Salvar referencia local
    SalvarEnvioLocal(IdEnvioFirebase, Quantidade);

    Log('========================================');
    Log('EXPORTACAO CONCLUIDA COM SUCESSO!');
    Log('ID Envio: ' + IdEnvioFirebase);
    Log('Registros: ' + Quantidade.ToString);
    Log('========================================');

  except
    on E: Exception do
      Log('Erro durante exportacao: ' + E.Message, False);
  end;

  ProgressBar.Visible := False;
  lblProgresso.Visible := False;
  btnExportar.Enabled := True;
  CarregarGridEnvios;
end;

procedure TFormExportarBoletim.btnReverterClick(Sender: TObject);
var
  IdEnvioFirebase: string;
  StatusAtual: string;
begin
  if FDQueryEnvios.IsEmpty then
  begin
    Log('Nenhum envio selecionado.', False);
    Exit;
  end;

  // Pegar dados do registro selecionado
  IdEnvioFirebase := FDQueryEnvios.FieldByName('ID_ENVIO_FIREBASE').AsString;
  StatusAtual := FDQueryEnvios.FieldByName('STATUS').AsString;

  if IdEnvioFirebase = '' then
  begin
    Log('ID Firebase invalido.', False);
    Exit;
  end;

  if StatusAtual = 'REVERTIDO' then
  begin
    ShowMessage('Este envio ja foi revertido anteriormente.');
    Exit;
  end;

  if MessageDlg(Format('Deseja reverter o envio?%s%s%s%d registros serao deletados do Firebase.', [
    sLineBreak, sLineBreak,
    'ID: ' + IdEnvioFirebase + sLineBreak,
    FDQueryEnvios.FieldByName('QUANTIDADE_REGISTROS').AsInteger]),
    mtConfirmation, [mbYes, mbNo], 0) = mrYes then
  begin
    btnReverter.Enabled := False;
    try
      ReverterEnvio(IdEnvioFirebase);
    finally
      btnReverter.Enabled := True;
      CarregarGridEnvios; // Atualizar grid para mostrar REVERTIDO
    end;
  end;
end;

procedure TFormExportarBoletim.btnAtualizarClick(Sender: TObject);
begin
  CarregarGridEnvios;
end;

procedure TFormExportarBoletim.btnFecharClick(Sender: TObject);
begin
  Close;
end;

