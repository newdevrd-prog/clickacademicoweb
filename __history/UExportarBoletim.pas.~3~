procedure TFormExportarBoletim.ExecutarQueryBoletim;
const
  SQL_BOLETIM =
    'SELECT DISTINCT ' +
    '    P.CODIGO AS CODPAI, ' +
    '    P.NOME AS NOMEPAI, ' +
    '    M.CODIGO AS CODMAE, ' +
    '    M.NOME AS NOMEMAE, ' +
    '    nat.CODIGOTURMA, ' +
    '    t.nome as TURMA, ' +
    '    a.NOME AS NOME_ALUNO, ' +
    '    nat.codigoaluno, ' +
    '    nat.CODIGODISCIPLINA, ' +
    '    d.NOME AS NOME_DISCIPLINA, ' +
    '    nat.MEDIA_1B, ' +
    '    nat.MEDIA_2B, ' +
    '    nat.MEDIA_3B, ' +
    '    nat.MEDIA_4B, ' +
    '    AF.B1, ' +
    '    AF.B2, ' +
    '    AF.B3, ' +
    '    AF.B4, ' +
    '    nat.NOTARECUPERACAO AS RECUP, ' +
    '    nat.MEDIAANUAL, ' +
    '    nat.MEDIAANUALFINAL, ' +
    '    AF.TOTAL AS TOTFALTAS, ' +
    '    s.NOME as SITUACAO ' +
    'FROM NOTAALUNOTURMA nat ' +
    'INNER JOIN turma            t ON t.codigo = nat.CODIGOTURMA ' +
    'INNER JOIN aluno            a ON a.codigo = nat.CODIGOALUNO ' +
    'LEFT  JOIN ALUNOFREQUENCIA AF ON AF.CODIGOTURMA = NAT.CODIGOTURMA AND NAT.CODIGOALUNO = AF.CODIGOALUNO ' +
    'LEFT  JOIN RESPONSAVEL     P ON P.CODIGO = a.CODIGOPAI ' +
    'LEFT  JOIN RESPONSAVEL     M ON M.CODIGO = a.CODIGOMAE ' +
    'INNER JOIN disciplina      d ON d.codigo = nat.codigodisciplina ' +
    'INNER JOIN SITUACAO        s ON s.codigo = nat.CODIGOSITUACAO ' +
    'WHERE extract(year from T.inicio) = :ANO_LETIVO ' +
    'ORDER BY nat.codigoturma, a.nome, d.codigo';
begin
  FDQueryBoletim.Close;
  FDQueryBoletim.SQL.Text := SQL_BOLETIM;
  FDQueryBoletim.ParamByName('ANO_LETIVO').AsInteger := AnoLetivo;
  FDQueryBoletim.Open;
  Log('Query executada para ano ' + AnoLetivo.ToString + '. Registros encontrados: ' + FDQueryBoletim.RecordCount.ToString);
end;

procedure TFormExportarBoletim.ExportarDados(const IdEnvioFirebase: string; out Quantidade: Integer);
const
  FIREBASE_PROJECT = 'clickacademico-342da';
  FIREBASE_API_KEY = 'AIzaSyA2-w2UfVhzN2prqJ2H0kecHYwLTC3XbkU';
  COLECAO = 'boletim_alunos';
var
  HTTP: TNetHTTPClient;
  JSONDoc, FieldsObj, ValueObj, IdEnvioObj: TJSONObject;
  RequestStream: TStringStream;
  Response: IHTTPResponse;
  URL: string;
  i: Integer;
  FieldName: string;
begin
  Quantidade := 0;
  if FDQueryBoletim.IsEmpty then
  begin
    Log('Nenhum dado para exportar.', False);
    Exit;
  end;
  
  HTTP := TNetHTTPClient.Create(nil);
  try
    HTTP.ContentType := 'application/json';
    URL := 'https://firestore.googleapis.com/v1/projects/' + FIREBASE_PROJECT + 
           '/databases/(default)/documents/' + COLECAO + '?key=' + FIREBASE_API_KEY;
    
    FDQueryBoletim.First;
    while not FDQueryBoletim.Eof do
    begin
      JSONDoc := TJSONObject.Create;
      FieldsObj := TJSONObject.Create;
      try
        // Adicionar campo id_envio referenciando o documento de envio
        IdEnvioObj := TJSONObject.Create;
        IdEnvioObj.AddPair('stringValue', IdEnvioFirebase);
        FieldsObj.AddPair('id_envio', IdEnvioObj);
        
        // Converter todos os campos do dataset para JSON Firestore
        for i := 0 to FDQueryBoletim.FieldCount - 1 do
        begin
          if FDQueryBoletim.Fields[i].IsNull then Continue;
          
          FieldName := FDQueryBoletim.Fields[i].FieldName.ToLower;
          ValueObj := TJSONObject.Create;
          
          case FDQueryBoletim.Fields[i].DataType of
            ftInteger, ftSmallint, ftShortint, ftLargeint:
              ValueObj.AddPair('integerValue', FDQueryBoletim.Fields[i].AsLargeInt.ToString);
            ftFloat, ftCurrency, ftBCD, ftFMTBcd:
              ValueObj.AddPair('doubleValue', TJSONNumber.Create(FDQueryBoletim.Fields[i].AsFloat));
            ftBoolean:
              ValueObj.AddPair('booleanValue', TJSONBool.Create(FDQueryBoletim.Fields[i].AsBoolean));
            ftDateTime, ftDate, ftTime:
              ValueObj.AddPair('timestampValue', FormatDateTime('yyyy-mm-dd"T"hh:nn:ss"Z"', 
                FDQueryBoletim.Fields[i].AsDateTime));
            else
              ValueObj.AddPair('stringValue', FDQueryBoletim.Fields[i].AsString);
          end;
          
          FieldsObj.AddPair(FieldName, ValueObj);
        end;
        
        JSONDoc.AddPair('fields', FieldsObj);
        
        RequestStream := TStringStream.Create(JSONDoc.ToJSON, TEncoding.UTF8);
        try
          Response := HTTP.Post(URL, RequestStream);
          
          if Response.StatusCode in [200, 201] then
          begin
            Inc(Quantidade);
            if (Quantidade mod 10) = 0 then
              Log('Exportados: ' + Quantidade.ToString + ' registros...');
          end
          else
          begin
            Log('Erro no registro ' + FDQueryBoletim.RecNo.ToString + ': ' + Response.StatusText, False);
          end;
        finally
          RequestStream.Free;
        end;
      finally
        JSONDoc.Free;
      end;
      
      FDQueryBoletim.Next;
    end;
    
    Log('Exportacao concluida. Total: ' + Quantidade.ToString + ' registros.');
  finally
    HTTP.Free;
  end;
end;

procedure TFormExportarBoletim.ReverterEnvio(const IdEnvioFirebase: string);
const
  FIREBASE_PROJECT = 'clickacademico-342da';
  FIREBASE_API_KEY = 'AIzaSyA2-w2UfVhzN2prqJ2H0kecHYwLTC3XbkU';
var
  HTTP: TNetHTTPClient;
  URL, QueryJSON: string;
  Response: IHTTPResponse;
  RequestStream: TStringStream;
  JSONRes, Doc: TJSONObject;
  Documents: TJSONArray;
  i: Integer;
  DocPath, DocId: string;
  TotalDeletados: Integer;
  SQL_UPDATE: string;
begin
  if IdEnvioFirebase = '' then
  begin
    Log('ID de envio invalido.', False);
    Exit;
  end;

  Log('========================================');
  Log('INICIANDO REVERSAO DO ENVIO');
  Log('ID: ' + IdEnvioFirebase);
  Log('========================================');

  HTTP := TNetHTTPClient.Create(nil);
  TotalDeletados := 0;
  try
    HTTP.ContentType := 'application/json';

    // 1. Buscar todos os documentos de boletim_alunos com este id_envio
    URL := 'https://firestore.googleapis.com/v1/projects/' + FIREBASE_PROJECT +
           '/databases/(default)/documents:runQuery?key=' + FIREBASE_API_KEY;

    QueryJSON :=
      '{ "structuredQuery": { ' +
      '  "from": [{"collectionId": "boletim_alunos"}], ' +
      '  "where": { "fieldFilter": { ' +
      '    "field": {"fieldPath": "id_envio"}, ' +
      '    "op": "EQUAL", ' +
      '    "value": {"stringValue": "' + IdEnvioFirebase + '"} ' +
      '  } } ' +
      '} }';

    Log('Buscando registros do boletim para deletar...');

    RequestStream := TStringStream.Create(QueryJSON, TEncoding.UTF8);
    try
      Response := HTTP.Post(URL, RequestStream);

      if Response.StatusCode = 200 then
      begin
        JSONRes := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
        if Assigned(JSONRes) then
        try
          // runQuery retorna objeto com campo 'document' array
          Documents := JSONRes.GetValue('document') as TJSONArray;
          if Assigned(Documents) then
          begin
            Log(Format('Encontrados %d registros para deletar.', [Documents.Count]));

            // Deletar cada documento
            for i := 0 to Documents.Count - 1 do
            begin
              Doc := Documents.Items[i] as TJSONObject;
              DocPath := Doc.GetValue('name').Value;
              DocId := Copy(DocPath, LastDelimiter('/', DocPath) + 1, MaxInt);

              // DELETE documento individual
              HTTP.Delete('https://firestore.googleapis.com/v1/' + DocPath + '?key=' + FIREBASE_API_KEY);
              Inc(TotalDeletados);

              if (TotalDeletados mod 10) = 0 then
              begin
                Log(Format('Deletados %d registros...', [TotalDeletados]));
                Application.ProcessMessages;
              end;
            end;

            Log(Format('Total de %d registros deletados do boletim_alunos.', [TotalDeletados]));
          end;
        finally
          JSONRes.Free;
        end;
      end;
    finally
      RequestStream.Free;
    end;

    // 2. Deletar o documento de envio_boletins
    Log('Deletando registro de envio...');
    HTTP.Delete('https://firestore.googleapis.com/v1/projects/' + FIREBASE_PROJECT +
                '/databases/(default)/documents/envio_boletins/' + IdEnvioFirebase +
                '?key=' + FIREBASE_API_KEY);

    // 3. Atualizar status no Firebird
    SQL_UPDATE := 'UPDATE ENVIO_BOLETINS SET STATUS = ''REVERTIDO'' WHERE ID_ENVIO_FIREBASE = :ID';
    try
      FDConnection.ExecSQL(SQL_UPDATE, [IdEnvioFirebase]);
      Log('Status atualizado para REVERTIDO no banco local.');
    except
      on E: Exception do
        Log('Aviso: Erro ao atualizar status local: ' + E.Message, False);
    end;

    Log('========================================');
    Log('REVERSAO CONCLUIDA COM SUCESSO!');
    Log(Format('Registros deletados: %d', [TotalDeletados]));
    Log('========================================');

    ShowMessage(Format('Envio revertido com sucesso!%s%d registros deletados do Firebase.', [
      sLineBreak + sLineBreak, TotalDeletados]));

  except
    on E: Exception do
    begin
      Log('Erro ao reverter envio: ' + E.Message, False);
      ShowMessage('Erro ao reverter envio: ' + E.Message);
    end;
  end;

  HTTP.Free;
end;

