procedure TFormExportarBoletim.PreencherComboAnoLetivo;
var
  AnoAtual, Ano: Integer;
  AnoInicial: Integer;
begin
  cmbAnoLetivo.Items.Clear;

  AnoAtual := YearOf(Now);
  AnoInicial := 2025;

  for Ano := AnoInicial to AnoAtual do
    cmbAnoLetivo.Items.Add(IntToStr(Ano));

  // Selecionar ano atual
  if cmbAnoLetivo.Items.Count > 0 then
    cmbAnoLetivo.ItemIndex := cmbAnoLetivo.Items.Count - 1;
end;

function TFormExportarBoletim.ObterAnoLetivoSelecionado: Integer;
begin
  if cmbAnoLetivo.ItemIndex >= 0 then
    Result := StrToInt(cmbAnoLetivo.Items[cmbAnoLetivo.ItemIndex])
  else
    Result := YearOf(Now);
end;

