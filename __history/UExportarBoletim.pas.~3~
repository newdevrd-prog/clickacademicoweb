procedure TFormExportarBoletim.CriarTabelaEnvioBoletins;
const
  SQL_CRIAR_TABELA =
    'CREATE TABLE ENVIO_BOLETINS (' +
    '  ID INTEGER PRIMARY KEY, ' +
    '  DATA_ENVIO TIMESTAMP DEFAULT CURRENT_TIMESTAMP, ' +
    '  ANO_LETIVO INTEGER, ' +
    '  ID_ENVIO_FIREBASE VARCHAR(100), ' +
    '  QUANTIDADE_REGISTROS INTEGER, ' +
    '  TURMA_CODIGO INTEGER, ' +
    '  STATUS VARCHAR(20) DEFAULT ''ENVIADO'' ' +
    ')';
  SQL_CRIAR_GENERATOR = 'CREATE SEQUENCE GEN_ENVIO_BOLETINS_ID';
  SQL_CRIAR_TRIGGER =
    'CREATE TRIGGER TR_ENVIO_BOLETINS_BI FOR ENVIO_BOLETINS ' +
    'ACTIVE BEFORE INSERT AS ' +
    'BEGIN ' +
    '  IF (NEW.ID IS NULL) THEN ' +
    '    NEW.ID = NEXT VALUE FOR GEN_ENVIO_BOLETINS_ID; ' +
    'END';
  SQL_CHECK_TABELA = 'SELECT 1 FROM RDB$RELATIONS WHERE RDB$RELATION_NAME = ''ENVIO_BOLETINS''';
var
  CheckQuery: TFDQuery;
  TabelaExiste: Boolean;
begin
  TabelaExiste := False;
  
  // Verifica se tabela ja existe usando TFDQuery (Open) ao inves de ExecSQL
  CheckQuery := TFDQuery.Create(nil);
  try
    CheckQuery.Connection := FDConnection;
    CheckQuery.SQL.Text := SQL_CHECK_TABELA;
    try
      CheckQuery.Open;
      TabelaExiste := not CheckQuery.IsEmpty;
      CheckQuery.Close;
    except
      TabelaExiste := False;
    end;
  finally
    CheckQuery.Free;
  end;
  
  if TabelaExiste then
  begin
    Log('Tabela ENVIO_BOLETINS ja existe.');
    Exit;
  end;

  // Criar tabela
  try
    FDConnection.ExecSQL(SQL_CRIAR_TABELA);
    Log('Tabela ENVIO_BOLETINS criada.');

    // Criar generator (sequencia)
    try
      FDConnection.ExecSQL(SQL_CRIAR_GENERATOR);
      Log('Sequencia GEN_ENVIO_BOLETINS_ID criada.');
    except
      // Generator pode ja existir, ignorar erro
    end;

    // Criar trigger
    try
      FDConnection.ExecSQL(SQL_CRIAR_TRIGGER);
      Log('Trigger TR_ENVIO_BOLETINS_BI criada.');
    except
      // Trigger pode ja existir, ignorar erro
    end;

    Log('Estrutura ENVIO_BOLETINS criada com sucesso.');
  except
    on E: Exception do
      Log('Erro ao criar tabela: ' + E.Message, False);
  end;
end;

function TFormExportarBoletim.CriarEnvioFirebase: string;
const
  FIREBASE_PROJECT = 'clickacademico-342da';
  FIREBASE_API_KEY = 'AIzaSyA2-w2UfVhzN2prqJ2H0kecHYwLTC3XbkU';
var
  HTTP: TNetHTTPClient;
  JSONDoc: TJSONObject;
  FieldsObj: TJSONObject;
  RequestStream: TStringStream;
  Response: IHTTPResponse;
  URL: string;
  JSONRes: TJSONObject;
  DocName: string;
begin
  Result := '';
  HTTP := TNetHTTPClient.Create(nil);
  try
    HTTP.ContentType := 'application/json';
    URL := 'https://firestore.googleapis.com/v1/projects/' + FIREBASE_PROJECT + 
           '/databases/(default)/documents/envio_boletins?key=' + FIREBASE_API_KEY;
    
    JSONDoc := TJSONObject.Create;
    FieldsObj := TJSONObject.Create;
    try
      // Campos do documento envio_boletins
      FieldsObj.AddPair('data_envio', TJSONObject.Create.AddPair('timestampValue', 
        FormatDateTime('yyyy-mm-dd"T"hh:nn:ss"Z"', Now)));
      FieldsObj.AddPair('ano_letivo', TJSONObject.Create.AddPair('integerValue', '2026'));
      FieldsObj.AddPair('status', TJSONObject.Create.AddPair('stringValue', 'ATIVO'));
      
      JSONDoc.AddPair('fields', FieldsObj);
      
      RequestStream := TStringStream.Create(JSONDoc.ToJSON, TEncoding.UTF8);
      try
        Log('Criando registro de envio no Firebase...');
        Response := HTTP.Post(URL, RequestStream);
        
        if Response.StatusCode in [200, 201] then
        begin
          JSONRes := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
          if Assigned(JSONRes) then
          try
            DocName := JSONRes.GetValue('name').Value;
            // Extrair apenas o ID do documento (ultima parte do path)
            Result := Copy(DocName, LastDelimiter('/', DocName) + 1, MaxInt);
            Log('Envio criado no Firebase. ID: ' + Result);
          finally
            JSONRes.Free;
          end;
        end
        else
        begin
          Log('Erro ao criar envio: ' + Response.StatusText, False);
        end;
      finally
        RequestStream.Free;
      end;
    finally
      JSONDoc.Free;
    end;
  finally
    HTTP.Free;
  end;
end;

